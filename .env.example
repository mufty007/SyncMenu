# Copy this file to .env and fill in the values from your Supabase project
# (Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Stripe dashboard links in platform admin (test vs live)
VITE_STRIPE_LIVE=false

# Supabase Edge Functions (set via `supabase secrets set`, not in Vercel)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRODUCT_ID=prod_UqPvU72LORrOEE
# STRIPE_SAAS_APP=syncmenu
# STRIPE_PORTAL_CONFIGURATION=bpc_...   (optional)
# SMTP2GO_API_KEY=your-smtp2go-api-key
# SMTP2GO_SENDER=hello@syncmenu.app
# SITE_ORIGIN=https://syncmenu.vercel.app
# UNSUBSCRIBE_SECRET=random-secret-for-unsubscribe-links
